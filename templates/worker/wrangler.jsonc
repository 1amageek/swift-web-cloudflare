{
  "name": "swiftweb-app",
  "main": "src/index.ts",
  "compatibility_date": "2024-11-01",
  "durable_objects": {
    "bindings": [
      { "name": "SWIFTWEB_ACTOR", "class_name": "SwiftWebActorDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["SwiftWebActorDO"] }
  ],
  "rules": [
    { "type": "CompiledWasm", "globs": ["**/*.wasm"] }
  ]
}
